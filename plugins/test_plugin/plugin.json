{
  "name": "Explation Tab",
  "unique_id": "explanet_tab",
  "version": "1.0.0",
  "description": "Adds a custom 'Explation' admin tab to the panel with useful information and tools.",
  "author": "Dragora Community",
  "license": "MIT",
  "icon": "fa-lightbulb",
  "hooks": {
    "admin_tabs": [
      {
        "id": "explation",
        "label": "Explation",
        "icon": "fa-lightbulb",
        "html": "<div id=\"explationApp\"><div style=\"padding:32px;text-align:center;color:var(--text3)\"><i class=\"fas fa-spinner fa-spin\" style=\"font-size:24px;display:block;margin-bottom:12px\"></i>Loading Explation...</div></div>"
      }
    ],
    "css": ["style.css"],
    "js": ["script.js"]
  }
}